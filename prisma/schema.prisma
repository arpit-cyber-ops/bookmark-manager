generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Bookmark {
  id                  Int                @id   @default(autoincrement())
  title               String
  url                 String
  category            String
  description         String        
  createdAt           DateTime              @default(now())
  isArchived         Boolean               @default(false)
}